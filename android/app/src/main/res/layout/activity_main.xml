<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="IoT Home Automation"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="20dp" />

        <TextView
            android:id="@+id/temperatureText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Temperature: -- °C"
            android:textSize="20sp"
            android:padding="12dp" />

        <TextView
            android:id="@+id/humidityText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Humidity: -- %"
            android:textSize="20sp"
            android:padding="12dp" />

        <TextView
            android:id="@+id/fanSpeedText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fan Speed: --"
            android:textSize="20sp"
            android:padding="12dp" />

        <TextView
            android:id="@+id/modeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mode: auto"
            android:textSize="20sp"
            android:padding="12dp" />

        <Switch
            android:id="@+id/autoModeSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Auto Mode"
            android:textSize="18sp"
            android:checked="true"
            android:padding="12dp" />

        <TextView
            android:id="@+id/manualSpeedLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manual Speed: 90"
            android:textSize="18sp"
            android:paddingTop="20dp" />

        <SeekBar
            android:id="@+id/manualSpeedSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="180"
            android:progress="90"
            android:padding="12dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Connecting..."
            android:textSize="16sp"
            android:paddingTop="20dp" />

    </LinearLayout>
</ScrollView>
